{
  "name": "vs-point/rb-premium",
  "version": "1.0.0",
  "type": "library",
  "description": "A PHP library for communication with the Raiffeisenbank Premium API.",
  "keywords": ["api", "raiffeisenbank", "rb", "premium", "banking"],
  "license": "MIT",
  "authors": [
    {
      "name": "Vít Steklý",
      "email": "stekly.vit@vs-point.cz"
    }
  ],
  "require": {
    "php": ">=8.2",
    "symfony/serializer": "^6.4|^7.0|^8.0",
    "symfony/property-access": "^6.4|^7.0|^8.0",
    "symfony/property-info": "^6.4|^7.0|^8.0",
    "phpdocumentor/reflection-docblock": "^5.4",
    "brick/math": "^0.12.0",
    "brick/date-time": "^0.7.0",
    "brick/money": "^0.10.0",
    "guzzlehttp/guzzle": "^7.9"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^2.0",
    "symplify/easy-coding-standard": "^12.0"
  },
  "autoload": {
    "psr-4": {
      "VsPoint\\RBPremium\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "VsPoint\\RBPremium\\Tests\\": "tests/"
    }
  }
}
